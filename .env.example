# Copy this file to .env and fill in real values: cp .env.example .env
#
# Database toggle:
#   NODB=true  -> use SQLite (zero setup, good for quick local dev)
#   NODB=false -> use the PostgreSQL settings below
NODB=true

# PostgreSQL connection (used only when NODB=false)
DB_NAME=teamboard
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
